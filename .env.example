POSTGRES_DB=aishop_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=123456
POSTGRES_PORT=5432

REDIS_PORT=6379
AUTH_TOKEN_TTL_DAYS=7

APP_PORT=8080
AGENT_PORT=5000

# AI Agent + RAG
AI_ENABLED=true
AI_PROVIDER=coze
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_API_KEY=
OPENAI_EMBEDDING_API_KEY=ollama
OPENAI_CHAT_BASE_URL=
OPENAI_EMBEDDING_BASE_URL=http://localhost:11434/v1
OPENAI_CHAT_MODEL=gpt-5.2
OPENAI_EMBEDDING_MODEL=nomic-embed-text
AI_TOP_K=6
COZE_CHAT_PATH=/run

# Agent container model config
AGENT_OPENAI_API_BASE=
AGENT_OPENAI_API_KEY=
AGENT_MODEL_NAME=

# Elasticsearch (hybrid retrieval)
ES_ENABLED=true
ES_HOST=localhost
ES_PORT=9201
ES_INDEX=products_search
ES_USERNAME=
ES_PASSWORD=

# Milvus
AI_MILVUS_ENABLED=true
AI_MILVUS_COLLECTION=products_rag_768
AI_MILVUS_DIMENSION=768
MILVUS_PORT=19530
MILVUS_HTTP_PORT=9091
ATTU_PORT=8000

# Optional MinIO creds used by Milvus standalone
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
